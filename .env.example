# MariaDB remoto (ex.: Hostinger/Coolify). Em dev local, a máquina precisa alcançar host:porta
# (internet/VPN; firewall pode bloquear). Teste: npm run db:test
DATABASE_URL=mysql://usuario:senha@host:5433/default
PORT=3000
SESSION_SECRET=troque-por-uma-chave-longa-e-aleatoria

# SMS Comtele (login por código e recuperação de senha)
# Chave em https://sms.comtele.com.br (área do programador)
# Sem COMTELE_AUTH_KEY em dev: código só no log do servidor e na resposta (DEV_SMS_ECHO)
# COMTELE_API_BASE_URL=https://sms.comtele.com.br
# COMTELE_AUTH_KEY=
# COMTELE_SENDER_ID=66912
DEV_SMS_ECHO=true

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://evo-gpqjmutl5vgest5yev0yc0sc.145.223.27.23.sslip.io
EVOLUTION_API_KEY=sua-api-key
EVOLUTION_INSTANCE=opalapa
EVOLUTION_WEBHOOK_SECRET=troque-por-um-token-secreto

# URL pública do Gestão (para registrar webhook na Evolution)
# Ex.: https://gestao.seudominio.com
APP_PUBLIC_URL=

# DeepSeek (geração de texto com IA no Marketing)
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_TIMEOUT_MS=60000

# Nextcloud (armazenamento de mídias do WhatsApp via WebDAV)
# Use usuário + senha ou app password do Nextcloud (não é a senha do MariaDB do container)
NEXTCLOUD_URL=
SERVICE_URL_NEXTCLOUD=
NEXTCLOUD_USER=
NEXTCLOUD_PASSWORD=
NEXTCLOUD_WHATSAPP_PATH=/opalapa/whatsapp
