{
  "name": "opalapa-gestao",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/free-port.js && concurrently -k -n api,web -c green,blue \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "node scripts/wait-api.js && vite",
    "dev:api": "node server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
    "user:create": "node scripts/create-user.js",
    "import:participantes": "node scripts/import-participantes.js",
    "preview": "npm run build && npm run start"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "concurrently": "^10.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.5",
    "ws": "^8.21.0"
  }
}
